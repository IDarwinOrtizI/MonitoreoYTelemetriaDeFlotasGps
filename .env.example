# ============================================================
# Variables de entorno para docker-compose
# ============================================================
# Copia este archivo a ".env" y ajusta los valores si quieres
# sobreescribir los defaults. Si no existe ".env", docker-compose
# usara los valores por defecto definidos en docker-compose.yml.
#
#   Windows (PowerShell):  copy .env.example .env
#   Linux/Mac:             cp .env.example .env
# ============================================================

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=monitoreoytelemetria
MYSQL_USER=gpsuser
MYSQL_PASSWORD=gpspass

# Spring Boot datasource (consumido por backend/src/main/resources/application.properties)
# SPRING_DATASOURCE_URL es opcional: si no se define, application.properties usa
# el default embebido (jdbc:mysql://localhost:3306/monitoreoytelemetria).
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
